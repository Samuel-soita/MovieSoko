{
  "version": 2,
  "name": "moviesoko",
  "buildCommand": "node scripts/vercel-build.js",
  "outputDirectory": "frontend",
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://moviesoko-api.onrender.com/api/:path*"
    },
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ]
}
