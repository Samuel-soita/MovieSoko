PORT=3000
APP_URL=https://your-app.onrender.com

# MongoDB Atlas — https://www.mongodb.com/cloud/atlas (free tier)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/cine254

# TMDB — https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# OMDb — http://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# Utelly via RapidAPI
RAPIDAPI_KEY=your_rapidapi_key_here
UTELLY_HOST=utelly-tv-shows-and-movies-availability-v1.p.rapidapi.com
WATCH_REGION=KE

# Auth
JWT_SECRET=change-this-to-a-long-random-string

# M-Pesa Daraja — https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://your-app.onrender.com/api/payments/callback
MPESA_ENV=sandbox
MPESA_MOVIE_PRICE=50

# Push notifications — run: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Affiliate IDs (optional)
AFFILIATE_NETFLIX=your_netflix_affiliate_id
AFFILIATE_SHOWMAX=your_showmax_affiliate_id
AFFILIATE_PRIME=your_prime_affiliate_id
AFFILIATE_DISNEY=your_disney_affiliate_id

SYNC_CRON=0 */6 * * *
